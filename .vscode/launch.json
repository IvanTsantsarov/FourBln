{
    "version": "0.2.0",

    "configurations": [
        {
            "name": "Debug FourBln (GNU ASM)",

            "type": "cppdbg",

            "request": "launch",

            "program": "${workspaceFolder}/build/FourBln",

            "args": [],

            "stopAtEntry": true,

            "cwd": "${workspaceFolder}",

            "environment": [],

            "externalConsole": false,

            "MIMode": "gdb",

            "miDebuggerPath": "gdb",

            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },

                {
                    "description": "GNU/AT&T syntax",
                    "text": "-gdb-set disassembly-flavor att",
                    "ignoreFailures": true
                }
            ],

            "preLaunchTask": "CMake Build"
        }
    ]
}
